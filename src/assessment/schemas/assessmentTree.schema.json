{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kneez Assessment Tree",
  "type": "object",
  "required": ["id", "version", "title", "entry_node_id", "nodes"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "entry_node_id": { "type": "string" },
    "nodes": {
      "type": "object",
      "patternProperties": {
        ".+": {
          "oneOf": [
            { "$ref": "#/definitions/questionNode" },
            { "$ref": "#/definitions/movementTestNode" },
            { "$ref": "#/definitions/assessmentNode" }
          ]
        }
      }
    }
  },
  "definitions": {
    "condition": {
      "oneOf": [
        {
          "type": "object",
          "properties": { "type": { "const": "always" } },
          "required": ["type"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "equals" },
            "key": { "type": "string" },
            "value": { "type": ["string", "number", "boolean"] }
          },
          "required": ["type", "key", "value"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "in" },
            "key": { "type": "string" },
            "any_of": {
              "type": "array",
              "items": { "type": ["string", "number", "boolean"] }
            }
          },
          "required": ["type", "key", "any_of"],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": { "const": "range" },
            "key": { "type": "string" },
            "min": { "type": "number" },
            "max": { "type": "number" }
          },
          "required": ["type", "key"],
          "additionalProperties": false
        }
      ]
    },
    "branchRule": {
      "type": "object",
      "properties": {
        "condition": { "$ref": "#/definitions/condition" },
        "next_node_id": { "type": "string" }
      },
      "required": ["condition", "next_node_id"],
      "additionalProperties": false
    },
    "recommendation": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["movement_mod", "exercise", "education", "referral", "other"]
        },
        "description": { "type": "string" },
        "video_id": { "type": "string" }
      },
      "required": ["id", "title", "type", "description"],
      "additionalProperties": false
    },
    "baseNode": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["question", "movement_test", "assessment"]
        },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "source": { "type": "string" }
      },
      "required": ["id", "type"],
      "additionalProperties": true
    },
    "questionNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "question" },
            "prompt": { "type": "string" },
            "help_text": { "type": "string" },
            "answer_type": {
              "type": "string",
              "enum": ["choice", "scale", "boolean", "free_text"]
            },
            "save_to": { "type": "string" },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "value": { "type": "string" },
                  "label": { "type": "string" }
                },
                "required": ["value", "label"],
                "additionalProperties": true
              }
            },
            "next": {
              "type": "array",
              "items": { "$ref": "#/definitions/branchRule" }
            }
          },
          "required": ["prompt", "answer_type", "save_to", "next"]
        }
      ]
    },
    "movementTestNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "movement_test" },
            "title": { "type": "string" },
            "instructions": { "type": "string" },
            "video_id": { "type": "string" },
            "metric_key": { "type": "string" },
            "metric_type": {
              "type": "string",
              "enum": ["pain_change", "pain_presence", "rom_quality", "other"]
            },
            "next": {
              "type": "array",
              "items": { "$ref": "#/definitions/branchRule" }
            }
          },
          "required": ["title", "instructions", "metric_key", "metric_type", "next"]
        }
      ]
    },
    "assessmentNode": {
      "allOf": [
        { "$ref": "#/definitions/baseNode" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "assessment" },
            "summary": { "type": "string" },
            "explanation": { "type": "string" },
            "region_id": { "type": "string" },
            "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
            "recommendations": {
              "type": "array",
              "items": { "$ref": "#/definitions/recommendation" }
            }
          },
          "required": ["summary", "explanation", "region_id", "recommendations"]
        }
      ]
    }
  }
}
