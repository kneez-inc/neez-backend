{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kneez Assessment Session State",
  "type": "object",
  "required": [
    "sessionId",
    "treeId",
    "treeVersion",
    "currentNodeId",
    "answers",
    "history",
    "startedAt",
    "updatedAt"
  ],
  "properties": {
    "sessionId": { "type": "string" },
    "treeId": { "type": "string" },
    "treeVersion": { "type": "string" },
    "currentNodeId": { "type": "string" },
    "answers": { "type": "object" },
    "history": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["node_id", "value", "timestamp"],
        "properties": {
          "node_id": { "type": "string" },
          "value": {},
          "timestamp": { "type": "string", "format": "date-time" }
        }
      }
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
